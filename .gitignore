# Data files — too large for git, generated by sync
data/sleeper/*.json
data/nfl/*.parquet
data/derived/*.parquet
data/external/*.parquet

# Keep the directory structure in git
!data/sleeper/.gitkeep
!data/nfl/.gitkeep
!data/derived/.gitkeep
!data/external/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment / secrets
.env
.streamlit/secrets.toml

# macOS
.DS_Store

# Streamlit config — keep config.toml, ignore secrets only
.streamlit/*
!.streamlit/config.toml
